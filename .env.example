# 🧬 Project Helix V4.0 - Command Center Configuration
# Instructions: Copy this file, rename it to '.env', and fill in your keys.
# WARNING: NEVER commit your real '.env' file to version control (Git).

# ==========================================
# 🧠 COGNITIVE CORE (GLM Engine)
# ==========================================
# Required: Get this from Zhipu AI (bigmodel.cn)
GLM_API_KEY="your_zhipu_api_key_here"

# ==========================================
# 🗂️ SECURE VAULT (Local Storage Layer)
# ==========================================
# Required: Absolute path to your Obsidian vault or local folder. 
# Note: Use forward slashes (/) even on Windows for best compatibility.
OBSIDIAN_PATH="D:/obsidian/vault/HELIX"

# ==========================================
# 🌃 GITHUB SENSOR (Open Source Hunter)
# ==========================================
# Optional but HIGHLY Recommended: Prevents GitHub API rate limiting.
# GITHUB_TOKEN="your_github_personal_access_token_here" ---only optional

# ==========================================
# 📧 APN DISPATCH (SMTP Email Layer)
# ==========================================
# Required: For automated morning/nightly intelligence drops.
SENDER_EMAIL="your_sender_email@163.com"
EMAIL_PASSWORD="your_email_app_password_here"
RECEIVER_EMAIL="your_target_email@university.edu"
# SMTP_SERVER="smtp.163.com"  # Optional: Defaults to 163 SMTP

# ==========================================
# 🎯 MANUAL OVERRIDE (For Standalone Terminal Mode)
# ==========================================
# Optional: Default target if running scripts directly via terminal (e.g., python hunter.py)
TARGET_TOPIC="Embodied AI"