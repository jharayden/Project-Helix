# 🔑 Arxiv Hunter Environment Variables Template
# Instructions: Copy this file, rename it to '.env', and fill in your own keys.

GLM_API_KEY=your_zhipu_api_key_here
SENDER_EMAIL=your_sender_email
EMAIL_PASSWORD=your_email_app_password_here
RECEIVER_EMAIL=your_target_email@university.edu
OBSIDIAN_PATH=D:\your\obsidian\vault\path  # Optional: For local markdown saving

# 🎯 Search Configuration (Optional)
# Change this to whatever you want to hunt! If left blank, it defaults to "Embodied AI".
TARGET_TOPIC="Large Language Models"