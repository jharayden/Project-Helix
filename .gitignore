# -------------------------------------------------------------------
# 🛡️ Project Helix V4.0 - Git Ignore Shield
# -------------------------------------------------------------------

# 1. 绝对机密与环境变量 (Critical Security)
.env
.env.*
!.env.example

# 2. 本地金库数据 (Local Vault Data - NEVER UPLOAD)
# 保护你的私人情报文件，防止被 Push 到公开仓库
Vault/
Arxiv_Papers/
GitHuber/
*.md

# 3. 允许上传的特例文档 (Except for the README)
!README.md

# 4. Python 缓存与垃圾文件 (Python Byte-compiled / Cache files)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# 5. 虚拟环境 (Virtual Environments)
venv/
.venv/
env/
.env_dir/

# 6. 操作系统与 IDE 垃圾 (OS & IDE files)
.DS_Store
Thumbs.db
.vscode/
.idea/